{#-
  STP.md.j2 — Jinja2 template for the Software Test Plan.

  Owns ALL standard scaffolding: H1 title, version/date/author block,
  section numbering (§1..§7), section titles, sub-section headings, and
  every table header. ALL prose content comes from the <stp> payload of
  doc/Project.xml; the §3 Test Catalogue and §4 LLR Coverage Matrix are
  computed from <tests> + <llrs>.

  Data shape (see tools/Project_xml_README.md for the full schema):

      project.metadata.{title,version,date,author}
      project.name           — long project name
      project.short_name     — short project name
      project.counts         — dict of {name: value} from <metadata>
      project.stp.introduction.{purpose, scope}
      project.stp.introduction.related            — list[str]
      project.stp.strategy.levels                 — list of
          .name, .source, .driver, .style
      project.stp.strategy.framework              — markdown
      project.stp.strategy.build_execution.{intro, steps, outro}
      project.stp.strategy.pass_fail              — list[str]
      project.stp.strategy.traceability_convention — markdown
      project.stp.integration_environment.{intro, fixtures, outro,
                                            artefact_keys, artefact_labels}
          fixtures: .name, .source, .artefacts (dict keyed by
                    artefact key, each with .key, .label, .path)
      project.stp.tooling                         — list of
          .name, .required_for, .notes
      project.stp.maintenance                     — markdown
      project.tests          — list of <file> objects:
          .path, .role, .count, .header
          .tests: .name, .purpose, .traces ([{target, ref}])
      project.flat_llrs      — every LLR in declaration order:
          .id, .text, .traces, .function_name, .function_number
      project.tests_by_llr   — dict[llr_id] -> [test_name, ...]
      project.tests_by_hlr   — dict[hlr_id] -> [test_name, ...]

  Files with count == 0 (e.g. integration-fixture compiler inputs) are
  skipped in the §3 catalogue.
-#}
{#- ===================== helper macros ===================== -#}
{%- macro hlr_refs(traces) -%}
{%- set hlrs = [] -%}
{%- for tr in traces if tr.target == "HLR" -%}
{%- set _ = hlrs.append(tr.ref) -%}
{%- endfor -%}
{%- if hlrs -%}
{% for r in hlrs %}`{{ r }}`{% if not loop.last %}, {% endif %}{% endfor %}
{%- else -%}
—
{%- endif -%}
{%- endmacro -%}

{%- macro llr_refs(traces) -%}
{%- set llrs = [] -%}
{%- for tr in traces if tr.target == "LLR" -%}
{%- set _ = llrs.append(tr.ref) -%}
{%- endfor -%}
{%- if llrs -%}
{% for r in llrs %}`{{ r }}`{% if not loop.last %}, {% endif %}{% endfor %}
{%- else -%}
—
{%- endif -%}
{%- endmacro -%}

{#- Collapse a multi-line purpose to a single line for table cells. -#}
{%- macro one_line(text) -%}
{{ text | replace('\n', ' ') | replace('  ', ' ') | trim }}
{%- endmacro -%}
